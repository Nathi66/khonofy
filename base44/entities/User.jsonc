{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "title": "Role",
      "enum": [
        "superuser",
        "admin",
        "staff"
      ],
      "default": "staff"
    },
    "department_id": {
      "type": "string",
      "title": "Department ID"
    },
    "admin_id": {
      "type": "string",
      "title": "Assigned Admin ID"
    },
    "phone": {
      "type": "string",
      "title": "Phone"
    }
  }
}